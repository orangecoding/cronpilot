PORT=3001
HOST=127.0.0.1
DB_PATH=./db/cronpilot.db
EXEC_TIMEOUT_MS=1800000
KEEP_MAX_FOR_HISTORY=5
LOG_LEVEL=info

# Optional. Set a secret token to protect the UI and API.
# If set, every request must include this token via ?token=TOKEN in the URL.
# Generate one with: openssl rand -hex 32
GATEWAY_TOKEN=
